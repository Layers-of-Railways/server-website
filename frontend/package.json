{
  "name": "frontend",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write .",
    "gh-pages": "cross-env BACKEND_URL=https://backend.s2.railways.dev && pnpm run build && npx gh-pages -d build"
  },
  "devDependencies": {
    "@sveltejs/adapter-auto": "^3.3.1",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.69.1",
    "@sveltejs/vite-plugin-svelte": "^3.1.2",
    "@tailwindcss/typography": "^0.5.20",
    "@types/eslint": "^8.56.12",
    "autoprefixer": "^10.5.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-svelte": "^2.46.1",
    "globals": "^15.15.0",
    "mdsvex": "^0.12.7",
    "postcss": "^8.5.16",
    "prettier": "^3.9.4",
    "prettier-plugin-svelte": "^3.5.2",
    "svelte": "^4.2.20",
    "svelte-check": "^3.8.6",
    "tailwindcss": "^3.4.19",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^5.4.21"
  },
  "type": "module",
  "dependencies": {
    "@types/three": "^0.168.0",
    "cross-env": "^7.0.3",
    "gh-pages": "^6.3.0",
    "three": "^0.168.0",
    "zod": "^3.25.76"
  },
  "trustedDependencies": [
    "svelte-preprocess"
  ]
}
